# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Choose provider: gemini (default) or hf
AI_PROVIDER=gemini

# Get a free key at: https://aistudio.google.com/app/apikey
# IMPORTANT: You must create a .env file with a valid API key for the app to work
GEMINI_API_KEY=AIza_your_api_key_here

# Optional overrides (defaults shown)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=512

# Optional Hugging Face provider config (used when AI_PROVIDER=hf)
# Create token: https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_hf_token_here
HF_MODEL=HuggingFaceH4/zephyr-7b-beta
HF_MAX_TOKENS=512

# Optional: override the SQLite file location
# DATABASE_URL=sqlite:////absolute/path/to/pastewise.db